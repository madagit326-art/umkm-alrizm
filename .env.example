# Contoh format yang benar:
# DATABASE_URL=postgres://postgres:YOUR_REAL_PASSWORD@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=postgres://postgres:YOUR_REAL_PASSWORD@db.xxxxx.supabase.co:5432/postgres

